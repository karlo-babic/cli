import subprocess
import platform
import sys
import re

def get_linux_version(module_name):
    """Linux specific: get version using modinfo."""
    try:
        output = subprocess.check_output(["modinfo", "-F", "version", module_name], 
                                         stderr=subprocess.DEVNULL).decode().strip()
        return output if output else "N/A"
    except:
        return "N/A"

def get_installed_drivers():
    os_name = platform.system()
    results = []

    try:
        if os_name == "Windows":
            # /V is verbose (includes version), /FO CSV makes it easy to parse
            output = subprocess.check_output(["driverquery", "/V", "/FO", "CSV"]).decode('utf-8', errors='ignore')
            return output

        elif os_name == "Linux":
            lsmod_out = subprocess.check_output(["lsmod"]).decode().splitlines()
            
            header = f"{'Module':<25} {'Version':<20} {'Used by':<20}"
            results.append(header)
            results.append("-" * len(header))

            for line in lsmod_out[1:]:
                parts = line.split()
                if len(parts) > 0:
                    module_name = parts[0]
                    used_by = parts[3] if len(parts) > 3 else ""
                    version = get_linux_version(module_name)
                    
                    if "nvidia" in module_name and version == "N/A":
                        try:
                            with open("/proc/driver/nvidia/version", "r") as f:
                                ver_match = re.search(r"Kernel Module\s+([\d\.]+)", f.read())
                                if ver_match: version = ver_match.group(1)
                        except: pass
                    
                    results.append(f"{module_name:<25} {version:<20} {used_by:<20}")
            
            return "\n".join(results)

        elif os_name == "Darwin":
            output = subprocess.check_output(["kextstat"]).decode()
            return output

    except Exception as e:
        return f"[-] Error fetching driver data: {str(e)}"

if __name__ == "__main__":
    search_term = sys.argv[1].lower() if len(sys.argv) > 1 else None
    
    print("\n=== System Drivers ===")
    driver_data = get_installed_drivers()
    
    if search_term and driver_data and not driver_data.startswith("[-]"):
        lines = driver_data.splitlines()
        # Keep header assuming first two lines are headers/separators
        header = lines[0:2] if len(lines) >= 2 else []
        matches = [line for line in lines[2:] if search_term in line.lower()]
        
        if matches:
            print("\n".join(header + matches))
        else:
            print(f"[-] No drivers found matching '{search_term}'")
    else:
        print(driver_data)
        
    print()