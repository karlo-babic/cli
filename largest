#!/usr/bin/env python3

import os
import sys

def human_readable(size):
    for unit in ["B", "K", "M", "G", "T"]:
        if size < 1024:
            return f"{size:.1f}{unit}"
        size /= 1024
    return f"{size:.1f}P"

def parse_args():
    path = "."
    limit = 10

    if len(sys.argv) >= 2:
        path = sys.argv[1]

    if len(sys.argv) >= 3:
        try:
            limit = int(sys.argv[2])
        except ValueError:
            print(f"[-] Invalid number for limit: {sys.argv[2]}")
            sys.exit(1)

    return path, limit

def collect_files(root):
    files = []
    last_len = 0

    for dirpath, _, filenames in os.walk(root):
        display = f"[*] Scanning: {dirpath}"
        # Truncate to terminal width safely to avoid line wraps ruining the clean carriage return
        display = display[:75] 
        print("\r" + display + " " * max(0, last_len - len(display)), end="", flush=True)
        last_len = len(display)

        for name in filenames:
            full_path = os.path.join(dirpath, name)
            try:
                size = os.path.getsize(full_path)
                files.append((size, full_path))
            except Exception:
                continue

    print("\r" + " " * last_len + "\r", end="", flush=True)
    return files

def main():
    root, limit = parse_args()

    if not os.path.exists(root):
        print(f"\n[-] Path does not exist: {root}\n")
        return

    print()
    files = collect_files(root)
    files.sort(key=lambda x: x[0], reverse=True)

    top = files[:limit]

    print(f"=== Largest Files in '{root}' ===")
    
    if not top:
        print("No files found.")
    else:
        for size, path in top:
            print(f"{human_readable(size):>8}  {path}")

    print()

if __name__ == "__main__":
    main()