#!/usr/bin/env python3

import os
import sys

def human_readable(size):
    for unit in ["B", "K", "M", "G", "T"]:
        if size < 1024:
            return f"{size:.1f}{unit}"
        size /= 1024
    return f"{size:.1f}P"

def parse_args():
    path = "."
    limit = 10

    if len(sys.argv) >= 2:
        path = sys.argv[1]

    if len(sys.argv) >= 3:
        try:
            limit = int(sys.argv[2])
        except ValueError:
            print(f"Invalid number: {sys.argv[2]}")
            sys.exit(1)

    return path, limit

def collect_files(root):
    files = []
    for dirpath, _, filenames in os.walk(root):
        for name in filenames:
            full_path = os.path.join(dirpath, name)
            try:
                size = os.path.getsize(full_path)
                files.append((size, full_path))
            except Exception:
                continue
    return files

def main():
    root, limit = parse_args()

    if not os.path.exists(root):
        print(f"Path does not exist: {root}")
        return

    files = collect_files(root)
    files.sort(key=lambda x: x[0], reverse=True)

    top = files[:limit]

    print(f"\nTop {len(top)} largest files in '{root}':\n")

    for size, path in top:
        print(f"{human_readable(size):>8}  {path}")

    print()

if __name__ == "__main__":
    main()