#!/usr/bin/env python3

import os
import shutil
import platform
import subprocess

def run_command(cmd):
    try:
        env = os.environ.copy()
        env["LC_ALL"] = "C"  # force standard locale
        return subprocess.check_output(cmd, shell=True, stderr=subprocess.DEVNULL, env=env).decode().strip()
    except Exception:
        return None

def get_cpu_info():
    cpu = {}
    cpu["model"] = run_command("lscpu | grep 'Model name' | cut -d: -f2").strip() if run_command("which lscpu") else platform.processor()
    cpu["cores"] = os.cpu_count()
    cpu["arch"] = platform.machine()
    return cpu

def get_ram_info():
    meminfo = {}
    try:
        with open("/proc/meminfo") as f:
            data = f.read()
        total = int([x for x in data.splitlines() if "MemTotal" in x][0].split()[1])
        available = int([x for x in data.splitlines() if "MemAvailable" in x][0].split()[1])
        meminfo["total_mb"] = total // 1024
        meminfo["available_mb"] = available // 1024
    except Exception:
        pass
    return meminfo

def get_gpu_info():
    gpu = run_command("lspci | grep -i 'vga\\|3d\\|2d'")
    return gpu or "Not available"

def get_disk_info():
    disks = []

    # Always check / and /home
    for path in ["/", "/home"]:
        try:
            usage = shutil.disk_usage(path)
            disks.append({
                "mount": path,
                "filesystem": path,
                "size": f"{usage.total // (1024**3)}G",
                "used": f"{usage.used // (1024**3)}G",
                "avail": f"{usage.free // (1024**3)}G",
                "use%": f"{int(usage.used / usage.total * 100)}%"
            })
        except Exception:
            pass

    # Check mounted subdirectories in /media and /mnt
    for base in ["/media", "/mnt"]:
        if os.path.exists(base):
            for name in os.listdir(base):
                full_path = os.path.join(base, name)
                if os.path.ismount(full_path):
                    try:
                        usage = shutil.disk_usage(full_path)
                        disks.append({
                            "mount": full_path,
                            "filesystem": full_path,
                            "size": f"{usage.total // (1024**3)}G",
                            "used": f"{usage.used // (1024**3)}G",
                            "avail": f"{usage.free // (1024**3)}G",
                            "use%": f"{int(usage.used / usage.total * 100)}%"
                        })
                    except Exception:
                        pass

    return disks

def get_os_info():
    return {
        "system": platform.system(),
        "release": platform.release(),
        "version": platform.version(),
        "hostname": platform.node()
    }

def print_section(title):
    print(f"\n=== {title} ===")

def print_key_values(data, suffix=""):
    for k, v in data.items():
        val_str = f"{v} {suffix}".strip() if suffix else str(v)
        print(f"  {k.capitalize():<12}: {val_str}")

def main():
    print_section("OS Information")
    print_key_values(get_os_info())

    print_section("CPU Information")
    print_key_values(get_cpu_info())

    print_section("Memory (RAM)")
    print_key_values(get_ram_info(), suffix="MB")

    print_section("GPU Information")
    gpu = get_gpu_info()
    if gpu and gpu != "Not available":
        for line in gpu.splitlines():
            print(f"  {line.strip()}")
    else:
        print(f"  {gpu}")

    print_section("Disk Usage")
    disks = get_disk_info()
    if not disks:
        print("  No disk information available.")
    else:
        header = f"  {'Mount':<15} {'Size':<6} {'Used':<6} {'Avail':<6} {'Use%'}"
        print(header)
        print("  " + "-" * (len(header) - 2))
        for d in disks:
            print(f"  {d['mount']:<15} {d['size']:<6} {d['used']:<6} {d['avail']:<6} {d['use%']}")
    
    print()

def run(args=None):
    main()

if __name__ == "__main__":
    main()