import subprocess
import platform
import os
import re

def get_thermal_data():
    os_name = platform.system()
    results = []

    try:
        if os_name == "Linux":
            thermal_path = "/sys/class/thermal/"
            if os.path.exists(thermal_path):
                for zone in os.listdir(thermal_path):
                    if zone.startswith("thermal_zone"):
                        try:
                            with open(os.path.join(thermal_path, zone, "type"), "r") as f:
                                label = f.read().strip()
                            with open(os.path.join(thermal_path, zone, "temp"), "r") as f:
                                temp = int(f.read().strip()) / 1000.0
                            results.append(f"  {label:<20}: {temp:.1f}\u00B0C")
                        except: continue

        elif os_name == "Windows":
            try:
                # Try WMI ACPI (may fail on most systems)
                cmd = [
                    "powershell",
                    "-Command",
                    "Get-CimInstance -Namespace root/wmi -ClassName MSAcpi_ThermalZoneTemperature | Select-Object -ExpandProperty CurrentTemperature"
                ]
                output = subprocess.check_output(cmd, stderr=subprocess.STDOUT).decode("utf-8", errors="ignore")
                temps = re.findall(r"(\d+)", output)
                for i, t in enumerate(temps):
                    celsius = (int(t) / 10.0) - 273.15
                    results.append(f"  ThermalZone {i:<8}: {celsius:.1f}\u00B0C")
            except:
                pass

            # Try NVIDIA GPU
            try:
                gpu_cmd = ["nvidia-smi", "--query-gpu=temperature.gpu", "--format=csv,noheader,nounits"]
                gpu_temp = subprocess.check_output(gpu_cmd, stderr=subprocess.DEVNULL).decode().strip()
                if gpu_temp:
                    results.append(f"  {'NVIDIA GPU':<20}: {gpu_temp}.0\u00B0C")
            except:
                pass

            # Fallback message if nothing at all
            if not results:
                results.append("  [-] CPU/GPU thermal data not available via standard Windows APIs. Consider LibreHardwareMonitor/OpenHardwareMonitor for full info.")

        elif os_name == "Darwin":  
            cmd = "sudo powermetrics -n 1 --samplers smc | grep -i 'CPU die temperature'"
            try:
                output = subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT).decode()
                results.append(f"  {output.strip()}")
            except:
                results.append("  [-] macOS thermal data requires 'sudo' or isn't accessible via standard CLI.")

        # --- Generic GPU Check (NVIDIA) ---
        try:
            gpu_cmd = ["nvidia-smi", "--query-gpu=temperature.gpu", "--format=csv,noheader,nounits"]
            gpu_temp = subprocess.check_output(gpu_cmd, stderr=subprocess.DEVNULL).decode().strip()
            if gpu_temp:
                results.append(f"  {'NVIDIA GPU':<20}: {gpu_temp}.0\u00B0C")
        except:
            pass

    except Exception as e:
        results.append(f"  [-] Error fetching data: {str(e)}")

    return "\n".join(results) if results else "  [-] No sensors detected."

if __name__ == "__main__":
    print("\n=== Thermal Sensors ===")
    print(get_thermal_data())
    print()