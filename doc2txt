#!/usr/bin/env python3
"""
Convert an EPUB file to plain text using the best available tool.

Priority:
1. mutool
2. pandoc
3. Pure Python fallback (no external dependencies)

Usage:
    python3 doc2txt.py file.epub
"""

import sys
import os
import subprocess
import zipfile
import re

def try_mutool(epub_path, txt_path):
    try:
        subprocess.run(["mutool", "convert", "-o", txt_path, epub_path], check=True, stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL)
        print(f"[+] Success: Used 'mutool' -> {txt_path}")
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False

def try_pandoc(epub_path, txt_path):
    try:
        subprocess.run(["pandoc", epub_path, "-t", "plain", "-o", txt_path], check=True, stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL)
        print(f"[+] Success: Used 'pandoc' -> {txt_path}")
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False

def python_fallback(epub_path, txt_path):
    text_parts = []
    try:
        with zipfile.ZipFile(epub_path, 'r') as zf:
            for name in zf.namelist():
                if name.lower().endswith(('.xhtml', '.html', '.htm')):
                    with zf.open(name) as f:
                        content = f.read().decode('utf-8', errors='ignore')
                        # Strip HTML tags crudely
                        text = re.sub(r'<[^>]+>', '', content)
                        text = re.sub(r'\n\s*\n', '\n\n', text)
                        text_parts.append(text.strip())
        
        with open(txt_path, 'w', encoding='utf-8') as out:
            out.write('\n\n'.join(filter(None, text_parts)))
            
        print(f"[+] Success: Used 'Python fallback' -> {txt_path}")
        return True
    except Exception as e:
        print(f"[-] Python fallback failed: {e}")
        return False

def epub_to_txt(epub_path):
    print("\n=== EPUB to TXT Converter ===")
    if not os.path.isfile(epub_path):
        print(f"[-] File not found: {epub_path}\n")
        return
        
    print(f"[*] Processing: {epub_path}")
    txt_path = os.path.splitext(epub_path)[0] + ".txt"

    if try_mutool(epub_path, txt_path):
        print()
        return
    if try_pandoc(epub_path, txt_path):
        print()
        return
        
    python_fallback(epub_path, txt_path)
    print()

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("\n=== EPUB to TXT Converter ===")
        print("Usage: python3 doc2txt.py <file.epub>\n")
    else:
        epub_to_txt(sys.argv[1])